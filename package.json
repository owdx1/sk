{
  "name": "sendkit-workspace",
  "private": "true",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev:cli": "bun run packages/cli/src/index.ts",
    "dev:local-mcp": "bun run packages/local-mcp/src/index.ts",
    "dev:remote-mcp": "bun run apps/remote-mcp/src/index.ts",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --deny-warnings",
    "lint: fix": "oxlint . --fix",
    "typecheck": "tsc --noEmit",
    "fix": "tsc --noEmit && oxlint . --deny-warnings && oxfmt . --write",
    "build:core": "bun run --filter @owdx-dev/sendkit-core build",
    "build:cli": "bun run --filter @owdx-dev/sendkit build",
    "build:local-mcp": "bun run --filter @owdx-dev/sendkit-mcp build",
    "release:pack:core": "bun run --filter @owdx-dev/sendkit-core pack:dry",
    "release:pack:cli": "bun run --filter @owdx-dev/sendkit pack:dry",
    "release:pack:local-mcp": "bun run --filter @owdx-dev/sendkit-mcp pack:dry"
  },
  "dependencies": {
    "@types/node": "^26.0.1"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
